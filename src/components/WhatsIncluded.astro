---
import CTAButton from './CTAButton.astro';

const items = [
  {
    icon: '📘',
    badge: 'Ebook',
    title: 'Negocio no Azul',
    subtitle: '22 paginas',
    description: 'Metodo A.Z.U.L. completo, com plano de 7 dias passo a passo. Linguagem direta, exemplos reais. Le no celular, no onibus, no almoco.',
    features: [
      '5 erros que matam o seu dinheiro',
      'Plano de 7 dias com acoes concretas',
      'Caso real: Dona Marta (18 anos de padaria)',
      'Os 3 numeros que voce precisa saber',
    ],
  },
  {
    icon: '📊',
    badge: 'Planilha',
    title: 'Planilha Financeira',
    subtitle: '8 abas com calculos automaticos',
    description: 'Voce so preenche entrada e saida. A planilha faz o resto: DRE, diagnostico, ponto de equilibrio e alertas inteligentes avisando onde o dinheiro esta vazando.',
    features: [
      'Fluxo de caixa diario automatizado',
      'DRE mensal - quanto voce lucra de verdade',
      'Diagnostico: status do seu negocio',
      'Alertas inteligentes nos numeros criticos',
    ],
    highlight: true,
  },
  {
    icon: '📋',
    badge: 'Guia',
    title: 'Guia de Uso da Planilha',
    subtitle: '14 paginas',
    description: 'Aba por aba, com exemplos, dicas e atalhos. Voce nao precisa saber Excel. Tem alguem te pegando pela mao.',
    features: [
      'Passo a passo de cada aba',
      'Exemplos preenchidos de negocios reais',
      'Dicas para bater a meta em 30 dias',
      'O que fazer se algo der errado',
    ],
  },
];

const WHATSAPP_GROUP = 'https://chat.whatsapp.com/BRGtbwulMsiEi5THnExsN5?mode=gi_t';
---

<section class="bg-white py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-6xl px-5">
    <div class="text-center mb-10 sm:mb-14">
      <div class="inline-block text-xs font-bold text-teal-600 uppercase tracking-widest mb-3">
        Pacote completo
      </div>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-extrabold text-navy-900 leading-tight mb-4">
        O que voce <span class="text-gradient-teal">recebe</span>
      </h2>
      <p class="text-base sm:text-lg text-navy-700 max-w-2xl mx-auto">
        3 materiais que se complementam para tirar seu negocio do vermelho sem voce ter que virar economista.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {items.map((item) => (
        <div class={`relative rounded-2xl p-6 sm:p-7 shadow-lg hover:shadow-2xl transition-all duration-300 ${item.highlight ? 'bg-gradient-to-br from-teal-500 to-teal-700 text-white ring-4 ring-gold-400/40 md:-translate-y-4' : 'bg-navy-50 border border-navy-100 text-navy-900'}`}>
          {item.highlight && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gold-400 text-navy-900 text-xs font-extrabold uppercase tracking-wider px-3 py-1 rounded-full shadow">
              Carro-chefe
            </div>
          )}

          <div class="text-5xl mb-3">{item.icon}</div>

          <div class={`text-xs font-bold uppercase tracking-widest mb-1 ${item.highlight ? 'text-gold-300' : 'text-teal-600'}`}>
            {item.badge} - {item.subtitle}
          </div>

          <h3 class={`font-display text-xl sm:text-2xl font-extrabold mb-3 ${item.highlight ? 'text-white' : 'text-navy-900'}`}>
            {item.title}
          </h3>

          <p class={`text-sm sm:text-base leading-relaxed mb-5 ${item.highlight ? 'text-teal-50' : 'text-navy-700'}`}>
            {item.description}
          </p>

          <ul class="space-y-2">
            {item.features.map((feature) => (
              <li class="flex items-start gap-2 text-sm">
                <svg class={`h-5 w-5 flex-shrink-0 mt-0.5 ${item.highlight ? 'text-gold-300' : 'text-teal-600'}`} fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class={item.highlight ? 'text-white' : 'text-navy-800'}>{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- BONUS: Grupo WhatsApp -->
    <div class="mt-10 sm:mt-14 max-w-3xl mx-auto">
      <div class="relative rounded-2xl p-6 sm:p-8 bg-gradient-to-br from-[#25D366] to-[#128C7E] text-white shadow-2xl overflow-hidden">
        <div class="absolute -top-8 -right-8 h-40 w-40 rounded-full bg-white/10 blur-2xl"></div>
        <div class="absolute -top-3 left-6 bg-gold-400 text-navy-900 text-[11px] font-extrabold uppercase tracking-widest px-3 py-1 rounded-full shadow">
          🎁 Bonus exclusivo
        </div>

        <div class="relative grid grid-cols-1 sm:grid-cols-[auto_1fr_auto] gap-5 sm:gap-6 items-center mt-3">
          <div class="flex-shrink-0 mx-auto sm:mx-0">
            <div class="flex h-16 w-16 sm:h-20 sm:w-20 items-center justify-center rounded-2xl bg-white/15 backdrop-blur">
              <svg class="h-10 w-10 sm:h-12 sm:w-12 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01C17.18 3.03 14.69 2 12.04 2zm0 18.15c-1.48 0-2.93-.4-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.26 8.26 0 01-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 012.42 5.83c0 4.54-3.7 8.23-8.24 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.17.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.39.11-.51.11-.11.25-.29.37-.43.12-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.77-1.84-.2-.48-.41-.42-.56-.43-.14-.01-.31-.01-.48-.01-.17 0-.43.06-.66.31-.23.25-.87.85-.87 2.07 0 1.22.89 2.4 1.01 2.57.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.07-.1-.23-.17-.48-.29z"/></svg>
            </div>
          </div>

          <div class="text-center sm:text-left">
            <h3 class="font-display text-xl sm:text-2xl font-extrabold mb-1">
              Grupo VIP no WhatsApp
            </h3>
            <p class="text-sm sm:text-base text-white/95 leading-relaxed">
              Comunidade exclusiva para tirar duvidas direto comigo, receber dicas semanais e trocar experiencias com outros empreendedores usando o metodo A.Z.U.L.
            </p>
          </div>

          <div class="text-center sm:text-right">
            <div class="text-[11px] uppercase tracking-widest text-white/70 font-bold">Valor</div>
            <div class="font-display text-2xl sm:text-3xl font-extrabold line-through opacity-80">R$ 150</div>
            <div class="text-xs font-bold uppercase tracking-wider text-gold-300">Gratis pra voce</div>
          </div>
        </div>

        <div class="relative mt-5 flex flex-col sm:flex-row gap-3 items-stretch">
          <a
            href={WHATSAPP_GROUP}
            target="_blank"
            rel="noopener"
            class="flex-1 inline-flex items-center justify-center gap-2 bg-white text-[#128C7E] hover:bg-gold-100 font-bold font-display text-sm sm:text-base uppercase tracking-wide px-5 py-3 rounded-xl shadow transition"
          >
            Ja quero entrar no grupo
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Value stack -->
    <div class="mt-10 sm:mt-14 max-w-2xl mx-auto bg-navy-50 rounded-2xl p-6 sm:p-8 border border-navy-100">
      <h3 class="font-display text-lg sm:text-xl font-bold text-navy-900 mb-5 text-center">Valor real do pacote</h3>
      <div class="space-y-3 mb-5">
        <div class="flex items-baseline justify-between text-sm sm:text-base">
          <span class="text-navy-700">Ebook "Negocio no Azul" (22 pgs)</span>
          <span class="font-bold text-navy-900">R$ 97</span>
        </div>
        <div class="flex items-baseline justify-between text-sm sm:text-base">
          <span class="text-navy-700">Planilha Financeira (8 abas)</span>
          <span class="font-bold text-navy-900">R$ 147</span>
        </div>
        <div class="flex items-baseline justify-between text-sm sm:text-base">
          <span class="text-navy-700">Guia de Uso (14 pgs)</span>
          <span class="font-bold text-navy-900">R$ 53</span>
        </div>
        <div class="flex items-baseline justify-between text-sm sm:text-base">
          <span class="text-navy-700">Bonus: Grupo VIP WhatsApp</span>
          <span class="font-bold text-navy-900">R$ 150</span>
        </div>
        <div class="border-t border-navy-200 pt-3 flex items-baseline justify-between">
          <span class="font-display font-bold text-navy-900">Total</span>
          <span class="font-display font-bold text-navy-900 line-through">R$ 447</span>
        </div>
        <div class="flex items-baseline justify-between bg-teal-50 rounded-lg p-3 -mx-2">
          <span class="font-display font-extrabold text-teal-700 text-lg">Voce paga hoje</span>
          <span class="font-display font-extrabold text-teal-700 text-2xl sm:text-3xl">R$ 97</span>
        </div>
      </div>
      <div class="text-center">
        <CTAButton size="lg" fullWidth={true} />
      </div>
    </div>
  </div>
</section>
