---
const WHATSAPP_NUMBER = '5551995736783';
const WHATSAPP_DISPLAY = '(51) 99573-6783';
const WHATSAPP_MSG = encodeURIComponent('Oi Anderson, tenho uma duvida sobre o Negocio no Azul!');
const INSTAGRAM = 'anderson.fct';
const YEAR = new Date().getFullYear();
---

