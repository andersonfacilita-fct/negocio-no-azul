---
const pains = [
  'Trabalha muito, vende bem - mas no fim do mês nunca sobra.',
  'Mistura dinheiro pessoal com o da empresa e se perde.',
  'Nunca sabe quanto realmente lucra no mês.',
  'Tira do caixa quando precisa, sem controle.',
  'Não sabe se o preço que cobra está certo.',
];
---

<section class="bg-white py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-4xl px-5">
    <div class="text-center mb-10 sm:mb-14">
      <div class="inline-block text-xs font-bold text-teal-600 uppercase tracking-widest mb-3">
        Reconheça o problema
      </div>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-extrabold text-navy-900 leading-tight">
        Você vive alguma dessas <span class="text-teal-600">situações</span>?
      </h2>
    </div>

    <ul class="space-y-3 sm:space-y-4 mb-10">
      {pains.map((pain) => (
        <li class="flex items-start gap-4 bg-navy-50 border-l-4 border-teal-500 rounded-r-xl p-4 sm:p-5 shadow-sm hover:shadow-md transition">
          <div class="flex-shrink-0 mt-0.5">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-red-100 text-red-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </div>
          </div>
          <p class="text-base sm:text-lg text-navy-800 leading-relaxed pt-0.5">{pain}</p>
        </li>
      ))}
    </ul>

    <div class="text-center bg-gradient-to-br from-navy-900 to-navy-800 text-white rounded-2xl p-6 sm:p-8">
      <p class="font-display text-lg sm:text-xl lg:text-2xl font-bold leading-snug">
        Se você marcou <span class="text-gold-400">2 ou mais</span>, este material foi feito pra você.
      </p>
    </div>
  </div>
</section>
